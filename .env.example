# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — secrets never leave your machine (Vercel gets them via its dashboard).

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Recall.ai → Dashboard → API Keys
RECALL_API_KEY=your-recall-api-key
# Region-specific base URL shown in your Recall dashboard, e.g. https://us-east-1.recall.ai
RECALL_BASE_URL=https://us-east-1.recall.ai

# Anthropic → console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your-anthropic-api-key

# Recall dashboard → Webhooks → your endpoint → Signing Secret (starts with whsec_)
RECALL_WEBHOOK_SECRET=whsec_your-signing-secret

# The app's own public URL (used to build OAuth redirect links)
APP_URL=https://sales-sense.vercel.app

# Google Cloud → APIs & Services → Credentials → OAuth client "salessense-web"
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
